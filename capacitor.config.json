{
  "appId": "br.com.faunacampo.app",
  "appName": "Fauna Campo",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "minWebViewVersion": 60
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a2e1a",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
